# ─── Base de datos (Neon) ───────────────────────────────────────────────────
DATABASE_URL="postgresql://neondb_owner:<password>@<host>-pooler.<region>.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://neondb_owner:<password>@<host>.<region>.aws.neon.tech/neondb?sslmode=require"

# ─── Railway asigna PORT automáticamente — NO lo pongas a mano ──────────────
# PORT= (Railway lo inyecta solo)

# ─── URLs de producción ──────────────────────────────────────────────────────
FRONTEND_ORIGIN="https://ceosmos-t8ee.vercel.app"

# ─── WebAuthn ────────────────────────────────────────────────────────────────
# RP_ID debe ser el dominio del FRONTEND (sin https://)
RP_ID="ceosmos-t8ee.vercel.app"
RP_NAME="CEOSMOS"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="<genera-uno-seguro-con: openssl rand -hex 32>"

# ─── Resend (correos) ────────────────────────────────────────────────────────
# Obtén tu API key en: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Con dominio propio verificado en Resend:
#   RESEND_FROM_EMAIL="CEOSMOS <noreply@tudominio.com>"
# Sin dominio propio (solo para pruebas, solo envía al email dueño de la cuenta Resend):
RESEND_FROM_EMAIL="CEOSMOS <onboarding@resend.dev>"
